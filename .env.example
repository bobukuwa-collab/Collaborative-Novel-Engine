# Supabase（https://supabase.com/dashboard のプロジェクト設定 > API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role（Supabase Dashboard > Settings > API > service_role）
# テストユーザー作成スクリプト・管理操作に使用
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI（https://aistudio.google.com/app/apikey から取得）
# AI 執筆継続（continue-story）に使用
GEMINI_API_KEY=

# Anthropic Claude（https://console.anthropic.com/ から取得）
# AI 完成度スコアリング（score-session）に使用
# 未設定でも執筆は動作するが、AI スコアカードは表示されない
ANTHROPIC_API_KEY=

# デプロイ後の本番URL（ローカル開発時は http://localhost:3000）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

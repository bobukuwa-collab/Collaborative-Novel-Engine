# Supabase（https://supabase.com/dashboard のプロジェクト設定 > API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# デプロイ後の本番URL（ローカル開発時は http://localhost:3000）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Service Role（Supabase Dashboard > Settings > API > service_role）
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI（https://aistudio.google.com/app/apikey から取得）
# AI小説継続生成・人格分析に使用
GEMINI_API_KEY=
